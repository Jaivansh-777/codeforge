# Database
DATABASE_URL=postgresql://user:password@hostname:5432/codeforge?sslmode=require

# Execution Limits
EXECUTION_TIMEOUT=10
EXECUTION_MEMORY_LIMIT=256
EXECUTION_CPU_LIMIT=1
EXECUTION_OUTPUT_LIMIT=65536
EXECUTION_MAX_FILE_SIZE=65536

# CORS
CORS_ORIGIN=http://localhost:3000

# Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000
